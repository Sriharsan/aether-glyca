# ── AETHER-Glyca Environment Variables ─────────────────────────────────
# Copy to .env — NEVER commit .env

# Gemini API (FREE — get at https://aistudio.google.com/app/apikey)
# No credit card needed. Works without key too (rule-based fallback)
GEMINI_API_KEY=your_gemini_key_here

# Database — SQLite works out of the box, no setup needed
DATABASE_URL=sqlite:///./aether_local.db

# Security
SECRET_KEY=aether-glyca-change-this-in-production-use-64-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# App
APP_ENV=development
FRONTEND_URL=http://localhost:5173
